# .env.local — copy this to .env.local and fill in the values
# Never commit the filled version to git

# Vercel Postgres — get from Vercel dashboard → Storage → your DB → .env.local tab
DATABASE_URL="postgres://..."
DIRECT_URL="postgres://..."

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""   # openssl rand -base64 32

# GitHub OAuth — create at github.com/settings/developers → OAuth Apps
GITHUB_ID=""
GITHUB_SECRET=""

# Phase 2 — Google Books
GOOGLE_BOOKS_API_KEY=""

# Phase 4 — Gemini
GEMINI_API_KEY=""
